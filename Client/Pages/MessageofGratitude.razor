<script>
    (function () {
        function init() {
            var sections = document.querySelectorAll('.year-section');
            var modEntries = document.querySelectorAll('.mod-entry');
            var btns = document.querySelectorAll('.timeline-year-btn');
            if (!sections.length) { setTimeout(init, 400); return; }

            var secObs = new IntersectionObserver(function (es) {
                es.forEach(function (e) {
                    if (e.isIntersecting) { e.target.classList.add('visible'); secObs.unobserve(e.target); }
                });
            }, { threshold: 0.08 });
            sections.forEach(function (s) { secObs.observe(s); });

            var entObs = new IntersectionObserver(function (es) {
                es.forEach(function (e) {
                    if (e.isIntersecting) {
                        var idx = Array.from(document.querySelectorAll('.mod-entry')).indexOf(e.target) % 4;
                        setTimeout(function () { e.target.classList.add('visible'); }, idx * 120);
                        entObs.unobserve(e.target);
                    }
                });
            }, { threshold: 0.1 });
            modEntries.forEach(function (el) { entObs.observe(el); });

            var actObs = new IntersectionObserver(function (es) {
                es.forEach(function (e) {
                    if (e.isIntersecting) {
                        btns.forEach(function (b) { b.classList.remove('active'); });
                        var m = document.querySelector('.timeline-year-btn[href="#' + e.target.id + '"]');
                        if (m) m.classList.add('active');
                    }
                });
            }, { threshold: 0.3 });
            sections.forEach(function (s) { actObs.observe(s); });
        }
        setTimeout(init, 500);
    })();
</script>
