@page "/MessageOfGratitude"

<style>
    body {
        background-image: url('images/SfondoClasifications.webp');
        background-size: cover;
        background-repeat: no-repeat;
        background-position: top center;
        background-attachment: fixed;
        background-color: #0a0500;
        min-height: 100vh;
        margin: 0;
    }

    .archive-wrapper {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: flex-start;
        padding: 60px 20px 120px;
        gap: 0;
        max-width: 1100px;
        margin: 0 auto;
    }

    .parchment {
        flex: 1;
        background: linear-gradient(160deg, #c8aa78 0%, #d4b882 20%, #c0a06a 40%, #cdb07a 60%, #b89460 80%, #c4a472 100%);
        border: 4px solid #6b4520;
        border-radius: 4px;
        box-shadow: 0 0 0 1px #8b5e30, 0 0 60px rgba(0,0,0,0.7), inset 0 0 40px rgba(80,40,10,0.2);
        position: relative;
        padding: 0 0 60px;
        min-width: 0;
    }

        .parchment::before {
            content: '';
            position: absolute;
            inset: -2px;
            background: radial-gradient(ellipse at 0% 0%, rgba(80,40,0,0.4) 0%, transparent 30%), radial-gradient(ellipse at 100% 0%, rgba(80,40,0,0.4) 0%, transparent 30%), radial-gradient(ellipse at 0% 100%, rgba(80,40,0,0.4) 0%, transparent 30%), radial-gradient(ellipse at 100% 100%, rgba(80,40,0,0.4) 0%, transparent 30%);
            pointer-events: none;
            border-radius: 4px;
            z-index: 1;
        }

    .parchment-header {
        text-align: center;
        padding: 50px 60px 30px;
        border-bottom: 2px solid rgba(80,40,10,0.3);
    }

        .parchment-header::after {
            content: 'â§';
            display: block;
            color: #6b4520;
            font-size: 1.4rem;
            margin-top: 10px;
            opacity: 0.6;
        }

    .parchment-title {
        font-family: 'Cinzel', serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: #3b2008;
        letter-spacing: 5px;
        text-transform: uppercase;
        text-shadow: 1px 1px 2px rgba(255,255,255,0.3);
        margin: 0 0 20px;
    }

    .parchment-intro {
        font-family: 'Georgia', serif;
        font-size: 1rem;
        line-height: 1.9;
        color: #2c1a08;
        font-style: italic;
        max-width: 600px;
        margin: 0 auto;
    }

    .year-section {
        padding: 40px 50px;
        border-bottom: 1px solid rgba(80,40,10,0.2);
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.8s ease, transform 0.8s ease;
    }

        .year-section.visible {
            opacity: 1;
            transform: translateY(0);
        }

        .year-section:last-child {
            border-bottom: none;
        }

    .year-label {
        font-family: 'Cinzel', serif;
        font-size: 3rem;
        font-weight: 700;
        color: #3b2008;
        letter-spacing: 8px;
        margin: 0 0 6px;
        line-height: 1;
        text-shadow: 1px 1px 0 rgba(255,255,255,0.4);
    }

    .year-subtitle {
        font-family: 'Georgia', serif;
        font-size: 0.82rem;
        color: #7a5030;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 20px;
    }

    .year-divider {
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(80,40,10,0.5), transparent);
        margin-bottom: 24px;
    }

    .img-box {
        width: 100%;
        height: 300px;
        border: 2px solid rgba(80,40,10,0.4);
        border-radius: 2px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(80,40,10,0.08);
        overflow: hidden;
    }

        .img-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .img-box-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        color: rgba(80,40,10,0.35);
        font-family: 'Cinzel', serif;
        font-size: 0.75rem;
        letter-spacing: 2px;
    }

        .img-box-placeholder::before {
            content: 'IMAGE';
            font-size: 1rem;
            opacity: 0.3;
        }

    .mod-list {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .mod-entry {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid rgba(80,40,10,0.1);
        opacity: 0;
        transform: translateX(-16px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }

        .mod-entry.visible {
            opacity: 1;
            transform: translateX(0);
        }

        .mod-entry:last-child {
            border-bottom: none;
        }

    .mod-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #6b4520;
        border: 1px solid #3b2008;
        margin-top: 7px;
        flex-shrink: 0;
    }

    .mod-info {
        flex: 1;
    }

    .mod-name {
        font-family: 'Cinzel', serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: #2c1a08;
        letter-spacing: 1px;
        margin-bottom: 3px;
    }

    .mod-desc {
        font-family: 'Georgia', serif;
        font-size: 0.88rem;
        color: #5a3820;
        line-height: 1.6;
        font-style: italic;
    }

    .mod-link {
        display: inline-block;
        margin-top: 4px;
        font-family: 'Cinzel', serif;
        font-size: 0.72rem;
        color: #8b4513;
        text-decoration: none;
        letter-spacing: 1px;
        border-bottom: 1px solid rgba(139,69,19,0.3);
        transition: color 0.2s;
    }

        .mod-link:hover {
            color: #3b2008;
        }

    .parchment-footer {
        text-align: center;
        padding: 24px 40px;
        color: rgba(59,32,8,0.45);
        font-family: 'Georgia', serif;
        font-size: 0.82rem;
        font-style: italic;
    }

    /* ── TIMELINE ── */
    .timeline-rail {
        width: 70px;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 50px 0;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        overflow-x: hidden;
        scrollbar-width: none;
        -ms-overflow-style: none;
        background: rgba(0,0,0,0.8);
        border-left: 1px solid rgba(212,175,55,0.15);
    }

        .timeline-rail::-webkit-scrollbar {
            display: none;
        }

        .timeline-rail::before {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 3px;
            background: linear-gradient(180deg, transparent 0%, #8b6914 4%, #ffd700 15%, #d4af37 50%, #ffd700 85%, #8b6914 96%, transparent 100%);
            z-index: 0;
        }

        .timeline-rail::after {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: calc(50% + 7px);
            width: 1px;
            background: linear-gradient(180deg, transparent, rgba(212,175,55,0.25), transparent);
            z-index: 0;
        }

    .t-connector {
        width: 1px;
        height: 28px;
        z-index: 1;
    }

    .timeline-year-btn {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 5px;
        text-decoration: none;
        padding: 10px 0;
        width: 100%;
        cursor: pointer;
        transition: all 0.3s;
    }

    .t-arrow-left {
        position: absolute;
        left: 4px;
        top: 50%;
        transform: translateY(-50%);
        width: 0;
        height: 0;
        border-top: 4px solid transparent;
        border-bottom: 4px solid transparent;
        border-right: 6px solid rgba(139,105,20,0.5);
        transition: all 0.3s;
    }

    .t-arrow-right {
        position: absolute;
        right: 4px;
        top: 50%;
        transform: translateY(-50%);
        width: 0;
        height: 0;
        border-top: 4px solid transparent;
        border-bottom: 4px solid transparent;
        border-left: 6px solid rgba(139,105,20,0.5);
        transition: all 0.3s;
    }

    .timeline-year-btn:hover .t-arrow-left {
        border-right-color: #ffd700;
    }

    .timeline-year-btn:hover .t-arrow-right {
        border-left-color: #ffd700;
    }

    .t-dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: #2a1400;
        border: 2px solid #8b6914;
        z-index: 2;
        transition: all 0.3s;
    }

    .timeline-year-btn:hover .t-dot,
    .timeline-year-btn.active .t-dot {
        background: #ffd700;
        border-color: #ffd700;
        box-shadow: 0 0 10px rgba(255,215,0,0.8);
        transform: scale(1.3);
    }

    .t-label {
        color: #907040;
        font-family: 'Cinzel', serif;
        font-size: 0.58rem;
        letter-spacing: 1px;
        text-align: center;
        transition: color 0.3s;
    }

    .timeline-year-btn:hover .t-label,
    .timeline-year-btn.active .t-label {
        color: #ffd700;
    }

    @@media (max-width: 768px) {
        .archive-wrapper {
            flex-direction: column;
            padding: 20px 12px 80px;
        }

        .timeline-rail {
            width: 100%;
            height: auto;
            flex-direction: row;
            position: sticky;
            top: 0;
            padding: 10px 20px;
            overflow-x: auto;
            overflow-y: hidden;
            border-left: none;
            border-bottom: 1px solid rgba(212,175,55,0.2);
            z-index: 50;
        }

            .timeline-rail::before, .timeline-rail::after {
                display: none;
            }

        .timeline-year-btn {
            flex-direction: row;
            gap: 6px;
            padding: 6px 12px;
            width: auto;
        }

        .t-arrow-left, .t-arrow-right {
            display: none;
        }

        .t-label {
            font-size: 0.65rem;
        }

        .parchment-title {
            font-size: 1.5rem;
        }

        .year-label {
            font-size: 2rem;
        }

        .year-section {
            padding: 24px 20px;
        }

        .parchment-header {
            padding: 28px 20px 18px;
        }

        .img-box {
            height: 180px;
        }
    }
</style>

