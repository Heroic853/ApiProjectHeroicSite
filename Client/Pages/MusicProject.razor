@page "/musicproj"
@using static Client.Pages.MusicProject


<style>
    body {
        background-image: url('images/MusicWallpaper.webp');
        background-size: cover;
        background-repeat: no-repeat;
        background-position: top center;
        background-attachment: fixed;
        background-color: black;
        min-height: 100vh;
    }

    .TitleVideo {
        text-align: center;
        color: cyan;
        font-family: 'Cinzel', serif;
        font-weight: 700;
        font-size: 3rem;
        text-transform: uppercase;
        letter-spacing: 4px;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.6);
        margin: 2rem 0;
    }
    
     .videos-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 30px;
        max-width: 1300px;
        margin: 40px auto;
        padding: 0 20px;
    }

    .video-card {
        display: flex;
        flex-direction: column;
        gap: 15px;
        cursor: pointer;
        transition: transform 0.3s;
    }

    .video-card:hover {
        transform: translateY(-5px);
    }

    .video-thumbnail {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%;
        background: #000;
        border: 3px solid cyan;
        border-radius: 10px;
        box-shadow: 0 0 15px rgba(255, 215, 0, 0.5);
        overflow: hidden;
    }

    .video-thumbnail img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .play-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.3s;
    }

    .video-card:hover .play-overlay {
        background: rgba(40, 190, 150, 0.3);
    }

    .play-btn {
        width: 70px;
        height: 70px;
        background: cyan;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        transition: transform 0.3s;
        box-shadow: 0 0 20px rgba(255, 215, 0, 0.6);
    }

    .video-card:hover .play-btn {
        transform: scale(1.15);
    }

    .video-label {
        text-align: center;
        color: white;
        font-family: 'Cinzel', serif;
        font-size: 1rem;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    /* MODALE */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.92);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: fadeIn 0.3s;
    }

    .modal-content {
        position: relative;
        width: 90%;
        max-width: 1000px;
        animation: scaleIn 0.3s;
    }

    .modal-video {
        position: relative;
        width: 100%;
        padding-bottom: 56.25%;
        background: #000;
        border: 3px solid cyan;
        border-radius: 10px;
        box-shadow: 0 0 40px rgba(255, 215, 0, 0.5);
        overflow: hidden;
    }

    .modal-video iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .modal-close {
        position: absolute;
        top: -45px;
        right: 0;
        background: blue;
        border: 2px solid cyan;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        color: cornflowerblue;
        font-size: 1.2rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
    }

    .modal-close:hover {
        background: blue;
        box-shadow: 0 0 15px rgba(255, 0, 0, 0.6);
        transform: scale(1.1);
    }

    .modal-title {
        text-align: center;
        color: black;
        font-family: 'Cinzel', serif;
        font-size: 1.1rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-top: 15px;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes scaleIn {
        from {
            transform: scale(0.8);
            opacity: 0;
        }

        to {
            transform: scale(1);
            opacity: 1;
        }
    }

    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .reveal.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .reveal-delay-1 {
        transition-delay: 0.1s;
    }

    .reveal-delay-2 {
        transition-delay: 0.2s;
    }

    .reveal-delay-3 {
        transition-delay: 0.3s;
    }

    .reveal-delay-4 {
        transition-delay: 0.4s;
    }

    @@media (max-width: 768px) {
        .videos-grid {
            grid-template-columns: 1fr;
        }

        .TitleVideo {
            font-size: 2rem;
        }
    }
</style>


