@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavManager

<div style="text-align: center;">
    <img src="images/Heroic853Icon.png" width="150" height="150">
</div>

<div class="page">
    <div class="page">
        <main>
            <button class="menu-button" @onclick="ToggleMenu">☰</button>
            <div class="content">
                @Body
            </div>

            <style>
                html, body {
                    width: 100%;
                    overflow-x: hidden;
                }

                .menu-destro ul {
                    list-style: none;
                    padding: 0;
                    margin: 14px 0;
                    display: flex;
                    flex-direction: column;
                    gap: 8px;
                }

                .menu-destro a {
                    display: block;
                    padding: 10px 15px;
                    text-decoration: none !important;
                    color: #d4af37 !important;
                    font-family: 'Cinzel', serif;
                    font-weight: 600;
                    font-size: 0.9rem;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    text-align: center;
                    background: rgba(0, 0, 0, 0.3);
                    border: 2px solid #8b0000;
                    border-radius: 5px;
                    transition: all 0.3s;
                    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
                }

                    .menu-destro a:hover {
                        color: #ffd700 !important;
                        background: rgba(139, 0, 0, 0.5);
                        border-color: #ff0000;
                        box-shadow: 0 0 15px rgba(255, 215, 0, 0.6);
                        transform: translateX(5px);
                    }

                    .menu-destro a.active {
                        color: #ffd700 !important;
                        background: rgba(139, 0, 0, 0.7);
                        border-color: #ffd700;
                        box-shadow: 0 0 20px rgba(255, 215, 0, 0.8);
                    }

                .menu-bottom-buttons {
                    display: flex;
                    justify-content: space-between;
                    gap: 10px;
                    padding: 15px 10px;
                    margin-top: 10px;
                }

                .menu-btn {
                    flex: 1;
                    padding: 10px 15px;
                    border: 2px solid #8b0000;
                    border-radius: 5px;
                    font-family: 'Cinzel', serif;
                    font-weight: bold;
                    font-size: 0.9rem;
                    text-decoration: none !important;
                    color: #c0c0c0 !important;
                    background: transparent;
                    text-align: center;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    transition: all 0.3s;
                    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.8);
                }

                    .menu-btn:hover {
                        background: rgba(139, 0, 0, 0.3);
                        border-color: #c0c0c0;
                        color: #e0e0e0 !important;
                        box-shadow: 0 0 10px rgba(192, 192, 192, 0.5);
                    }

                .menu-button {
                    position: fixed;
                    top: 10px;
                    right: 10px;
                    font-size: 2rem;
                    background: #8b0000;
                    color: gold;
                    border: 2px solid gold;
                    border-radius: 10px;
                    padding: 10px 20px;
                    cursor: pointer;
                    z-index: 1000;
                    transition: all 0.3s;
                }

                    .menu-button:hover {
                        background: #a01010;
                        box-shadow: 0 0 10px rgba(255, 215, 0, 0.4);
                        transform: scale(1.05);
                    }

                .close-button {
                    display: none !important;
                }

                .welcome-message {
                    padding: 15px;
                    margin: 15px 0;
                    text-align: center;
                    color: #ffd700;
                    font-family: 'Cinzel', serif;
                    font-size: 1.1rem;
                    font-weight: bold;
                    background: rgba(139, 0, 0, 0.3);
                    border: 2px solid #d4af37;
                    border-radius: 8px;
                    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
                }

                .sign-out-btn {
                    width: 100%;
                    padding: 10px 15px;
                    border: 2px solid #8b0000;
                    border-radius: 5px;
                    font-family: 'Cinzel', serif;
                    font-weight: bold;
                    font-size: 0.9rem;
                    text-decoration: none !important;
                    color: #ff6b6b !important;
                    background: rgba(139, 0, 0, 0.3);
                    text-align: center;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    transition: all 0.3s;
                    cursor: pointer;
                    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.8);
                    margin-top: 10px;
                }

                    .sign-out-btn:hover {
                        background: rgba(139, 0, 0, 0.6);
                        border-color: #ff0000;
                        color: #ffffff !important;
                        box-shadow: 0 0 15px rgba(255, 0, 0, 0.5);
                    }

                @@media (max-width: 480px) {
                    .menu-destro {
                        width: 70% !important;
                        max-width: 280px !important;
                        height: 100vh !important;
                        padding: 15px 10px !important;
                    }

                        .menu-destro img {
                            width: 120px !important;
                            height: 120px !important;
                            margin: 10px auto;
                        }

                        .menu-destro a {
                            padding: 8px 10px !important;
                            font-size: 0.75rem !important;
                            letter-spacing: 0.5px !important;
                        }

                        .menu-destro ul {
                            gap: 5px !important;
                            margin: 10px 0 !important;
                        }

                    .menu-bottom-buttons {
                        flex-direction: row !important;
                        gap: 5px !important;
                        padding: 10px 5px !important;
                        position: sticky;
                        bottom: 0;
                        background: linear-gradient(to bottom, transparent, #1a0f0a 20%);
                        padding-top: 20px !important;
                    }

                    .menu-btn {
                        padding: 8px 10px !important;
                        font-size: 0.7rem !important;
                    }

                    .menu-button {
                        top: 12px !important;
                        right: 12px !important;
                        font-size: 1.5rem !important;
                        padding: 8px 15px !important;
                    }
                }
            </style>
        </main>

        @if (menuOpen)
        {
            <div class="menu-destro">
                <button class="close-button" @onclick="ToggleMenu"></button>
                <img src="images/Heroic853Icon.png" width="200" height="200">

                <AuthorizeView>
                    <Authorized>
                        @* Messaggio di benvenuto *@
                        <div class="welcome-message">
                            ⚔️ Welcome, Hunter! ⚔️
                            <br />
                            <span style="font-size:0.85rem; color:#c0c0c0;">
                                @context.User.FindFirst("email")?.Value
                            </span>
                        </div>

                        <ul>
                            <NavLink href="" Match="NavLinkMatch.All">Introduction</NavLink>
                            <NavLink href="MessageOfGratitude">Message of Gratitude</NavLink>
                            <NavLink href="videopage">Video</NavLink>
                            <NavLink href="forbiddenMonsters">Forbidden Monsters</NavLink>
                            <NavLink href="dragonList">Monster Choise & Feedbacks</NavLink>
                            <NavLink href="UserProfile">User Settings</NavLink>

                            @* Admin check tramite claim Auth0 *@
                            @if (context.User.IsInRole("Admin"))
                            {
                                <NavLink href="aniversarytable">Admin Data Table</NavLink>
                                <NavLink href="UserTable">Users</NavLink>
                            }
                        </ul>

                        <button class="sign-out-btn" @onclick="SignOut">Sign Out</button>
                    </Authorized>

                    <NotAuthorized>
                        <ul>
                            <NavLink href="" Match="NavLinkMatch.All">Introduction</NavLink>
                            <NavLink href="MessageOfGratitude">Message of Gratitude</NavLink>
                            <NavLink href="videopage">Video</NavLink>
                            <NavLink href="forbiddenMonsters">Forbidden Monsters</NavLink>
                        </ul>

                        <div class="menu-bottom-buttons">
                            <NavLink class="menu-btn" href="loginHeroic">Sign In</NavLink>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        }
    </div>

    @code {
        bool menuOpen = false;

        void ToggleMenu()
        {
            menuOpen = !menuOpen;
        }

        void SignOut()
        {
            menuOpen = false;
            NavManager.NavigateTo("authentication/logout", forceLoad: true);
        }
    }
</div>

<script>
    window.addEventListener('resize', function() {
        setTimeout(function() {
            window.dispatchEvent(new Event('resize'));
        }, 100);
    });
</script>
<p style="text-align: center; color: white;">
    ©Heroic853 2026
</p>